# Copy this file to .env and fill in your values.
# The .env file is listed in .gitignore and must never be committed.

# Full DocumentDB connection URI — TLS params must be visible here so the intent is auditable.
DOCUMENTDB_URI=mongodb://<username>:<password>@localhost:10260/?tls=true&tlsAllowInvalidCertificates=true&authMechanism=SCRAM-SHA-256

# Only safe for the local dev container.  Never set to true against a real deployment.
DOCUMENTDB_ALLOW_INVALID_CERTS=true

# Database name inside DocumentDB
DOCDB_DB_NAME=activitydb
