# DocumentDB connection string
# For local Docker: use the default below
# For Azure: run scripts/deploy-azure.sh and paste the output here
DOCUMENTDB_URI=mongodb://admin:documentdb@localhost:10260/personal_memory?authSource=admin&tls=true&tlsAllowInvalidCertificates=true&directConnection=true

# Database name (override for Azure or custom setups)
DB_NAME=personal_memory

# MCP server port
MCP_SERVER_PORT=3000

# Bearer token for API authentication
AUTH_TOKEN=dev-token-change-me

# Set to "true" to disable authentication (development only)
# NO_AUTH=true

# Log level: debug, info, warn, error
LOG_LEVEL=info

# Rate limiting
RATE_LIMIT_MAX=60
RATE_LIMIT_WINDOW_MS=60000

# Ollama settings for vector search (optional — server works without it)
# Install Ollama: https://ollama.com and run: ollama pull nomic-embed-text
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_EMBEDDING_MODEL=nomic-embed-text
EMBEDDING_DIMENSIONS=768
